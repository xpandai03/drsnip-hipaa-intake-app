# Zapier Catch Hook URLs — receive form submissions server-side. /api/submit
# dispatches to one of these three based on the ?source= URL param the form
# was loaded with. Each Zap maps the payload onto the corresponding Salesforce
# fields — Survey_Detail__c in particular drives Apex Campaign routing
# (see CAMPAIGN_AUDIT_FINDINGS.md).
#
# All three should be set in any environment that handles real submissions.
# /api/submit returns 500 if the matching var is missing for the request's source.

# Federal-direct channel — ?source=federal (or unrecognized/missing).
# Survey_Detail__c=DC SOFA -> Apex routes via Federal_Agency__c -> agency Campaign.
ZAPIER_WEBHOOK_FEDERAL=

# Internal Marketing channel — ?source=internal.
# Survey_Detail__c=DC SOFA 2 -> Apex routes to "INTERNAL MARKETING" Campaign.
ZAPIER_WEBHOOK_INTERNAL=

# FNN Marketing channel — ?source=fnn.
# Survey_Detail__c=DC SOFA 3 -> Apex routes to FNN Campaign.
ZAPIER_WEBHOOK_FNN=

# Legacy single-webhook var. No longer read by /api/submit. Left here for
# reference only; remove after you've confirmed all three vars above are set.
# ZAPIER_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Phase 2 — CJC Intake Console
# ---------------------------------------------------------------------------

# Vercel Postgres connection string. Local dev: copy from `vercel env pull`
# or paste the pooled `*_DATABASE_URL` value from the Vercel dashboard.
# Read by lib/db/src/index.ts. Required for any Phase 2 server endpoint
# and for `pnpm --filter @workspace/db push`.
DATABASE_URL=

# Google OAuth — admin sign-in. Set up in Raunek's Google Cloud project
# (`xpandai.com` org); migrate to a CJC-owned project in Phase 3.
# Authorized redirect URIs:
#   https://<vercel-prod-url>/api/auth/callback
#   http://localhost:3000/api/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated emails allowed to sign in to /admin.
# Non-matching emails get 403 on the OAuth callback.
ADMIN_EMAIL_ALLOWLIST=chris@cjcwealth.com,mel@cjcwealth.com,raunek@xpandai.com

# Random hex string used to sign the session cookie. Generate with
# `openssl rand -hex 32`. Rotate to invalidate every active session.
SESSION_COOKIE_SECRET=

# Salesforce direct push — Connected App Client Credentials Flow.
# See PLAN_SF_DIRECT_PUSH.md for the auth-helper plan that Sprint 2 ships.
SF_INSTANCE_URL=https://cjcwealth.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_VERSION=v59.0
