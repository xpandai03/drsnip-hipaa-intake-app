# DrSnip intake form — local environment.
# Copy to `.env.local` and fill in. Never commit `.env.local`.
#
# Phase 1 (DrSnip): the CJC-era Zapier / Salesforce / TimeTap / Google-OAuth
# variables were removed along with their subsystems. Only the variables below
# are read by the current codebase.

# PostgreSQL connection string. Required by every database-backed route
# (form submit + the admin console). Read by lib/db/src/index.ts.
DATABASE_URL=

# Runtime environment. "production" makes session cookies Secure-only.
# Defaults to development behavior when unset.
NODE_ENV=development

# Port the api-server (api-server/index.ts) listens on. Defaults to 8080.
PORT=8080

# NOTE: admin auth uses opaque server-side session tokens (random id stored
# in the `sessions` table), so no signing secret is needed today. If a signed
# cookie is introduced later, add SESSION_SECRET here.
